# Playro / Playro environment example
# Copy this file to .env for local overrides. Keep real secrets out of Git.

# Use the deterministic local Roblox generator for smoke tests. Set to 1 only
# after your local Hermes runtime/provider credentials are configured.
PLAYRO_USE_HERMES_AGENT=0

# Local backend API. The desktop app starts this automatically and generates
# PLAYRO_API_TOKEN for its own protected requests.
# SECURITY NOTE: For safety, always bind to 127.0.0.1 (localhost) to prevent
# exposing the backend server and its filesystem access to the local network.
HERMES_ROBLOX_API_HOST=127.0.0.1
HERMES_ROBLOX_API_PORT=8765
PLAYRO_API_TOKEN=
PLAYRO_ALLOWED_ORIGINS=file://,app://playro,http://localhost:8765,http://127.0.0.1:8765

# Optional local output/runtime overrides.
PLAYRO_DATA_DIR=
PLAYRO_HERMES_BIN=
PLAYRO_ROJO_BIN=
PLAYRO_HERMES_AGENT_TIMEOUT=45
PLAYRO_MAX_PROMPT_CHARS=4000
PLAYRO_MAX_CONCURRENT_BUILDS=2
PLAYRO_SSE_MAX_WAIT_SECS=300
PLAYRO_ALLOW_LOCAL_GENERATOR=1
